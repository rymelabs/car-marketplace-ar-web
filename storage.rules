rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    match /car-models/{carId}/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /car-media/{carId}/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pending-uploads/{uploadId}/{fileName} {
      allow read, write: if isAdmin();
    }
  }
}
